YOUTUBE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Reddit desactivado temporalmente
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=trendprompt-engine/1.0
TIKTOK_HEADLESS=true
HTTP_PROXY=
HTTPS_PROXY=

# Deploy / infraestructura
APP_ENV=development
DEBUG=true
API_PREFIX=/api

# Postgres (local / docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sistemas123
POSTGRES_DB=db_trends
# DATABASE_URL local ejemplo:
# DATABASE_URL=postgresql+asyncpg://postgres:sistemas123@localhost:5432/db_trends
# DATABASE_URL docker ejemplo (desde contenedor backend/worker):
# DATABASE_URL=postgresql+asyncpg://postgres:sistemas123@postgres:5432/db_trends
# Railway: usar la DATABASE_URL que entrega el servicio Postgres/plugin.

# REDIS_URL=redis://localhost:6379/0
USE_REDIS_CACHE=true
USE_CELERY=true
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live-trends

# Prompt Feed connectors
PROMPT_FEED_CACHE_TTL=900
LEXICA_API_BASE_URL=https://lexica.art/api/v1

# PromptHero opcional: pega aquí tu bearer token y, si hace falta, ajusta endpoints
PROMPTHERO_API_BASE_URL=https://api.prompthero.com
PROMPTHERO_ACCESS_TOKEN_URL=https://api.prompthero.com/v1/access_token
PROMPTHERO_RANDOM_URL=https://api.prompthero.com/v1/random
PROMPTHERO_THUMBNAILS_URL=https://api.prompthero.com/v1/thumbnails
PROMPTHERO_AUTOCOMPLETE_URL=https://api.prompthero.com/v1/autocomplete
PROMPTHERO_RELATED_URL=https://api.prompthero.com/v1/related
PROMPTHERO_BEARER_TOKEN=

# Krea Open Prompts / GitHub públicos
KREA_OPEN_PROMPTS_REPO_URL=https://github.com/krea-ai/open-prompts
KREA_OPEN_PROMPTS_CSV_URL=https://raw.githubusercontent.com/krea-ai/open-prompts/main/data/1k.csv
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_RAW_BASE_URL=https://raw.githubusercontent.com
GITHUB_TOKEN=
PROMPT_FEED_DEFAULT_GITHUB_OWNER=krea-ai
PROMPT_FEED_DEFAULT_GITHUB_REPO=open-prompts
PROMPT_FEED_DEFAULT_GITHUB_BRANCH=main
PROMPT_FEED_DEFAULT_GITHUB_PATH=data/1k.csv
CIVITAI_API_BASE_URL=https://civitai.com/api/v1
CIVITAI_API_KEY=

# Ingestion hardening
SOURCE_INTERVAL_GOOGLE_MINUTES=30
SOURCE_INTERVAL_YOUTUBE_MINUTES=30
SOURCE_INTERVAL_REDDIT_MINUTES=20
SOURCE_INTERVAL_TIKTOK_MINUTES=60
INGESTION_JITTER_MIN_SECONDS=5
INGESTION_JITTER_MAX_SECONDS=25
SOURCE_RETRY_ATTEMPTS=3
SOURCE_RETRY_BASE_DELAY_SECONDS=2
SOURCE_CACHE_TTL_SECONDS=1800
INGESTION_LOCK_TTL_SECONDS=900
